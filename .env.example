# ============================================================
# CheckMate / Suraksha 2.0 — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./checkmate.db
# Production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://checkmate:password@localhost:5432/checkmate

REDIS_URL=redis://localhost:6379/0

# --- LLM Settings ---
# "google" = Gemma 4 31B via Google AI Studio (recommended)
# "ollama" = Local Ollama (offline dev fallback)
LLM_PROVIDER=ollama
LLM_MODEL=gemma:2b

# Get your free API key from: https://aistudio.google.com/app/apikey
GEMMA_API_KEY=your_google_ai_studio_api_key_here

# Ollama settings (only needed if LLM_PROVIDER=ollama)
OLLAMA_API_BASE=http://localhost:11434

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120.0

# --- File Upload ---
UPLOAD_MAX_SIZE_MB=50
UPLOAD_TEMP_DIR=./tmp/checkmate-uploads
OUTPUT_DIR=./tmp/checkmate-output

# --- OCR (Tesseract) ---
# Windows path — update to your Tesseract install location
TESSERACT_CMD=D:\Tessaract-OCR\tesseract.exe
# Linux/Mac: TESSERACT_CMD=tesseract

# --- YOLOv8 Seal Detection ---
YOLO_MODEL_PATH=models/yolov8/seal_detector.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# --- Risk Thresholds ---
RISK_GREEN_THRESHOLD=0.30    # score < 0.30 → GREEN (Approved)
RISK_RED_THRESHOLD=0.60      # score >= 0.60 → RED (AI Investigation)

# --- Fusion Weights — SCANNED documents (must sum to 1.0) ---
WEIGHT_ELA=0.35
WEIGHT_METADATA=0.25
WEIGHT_SEAL=0.25
WEIGHT_NLP=0.15

# --- Fusion Weights — DIGITAL (native PDF) documents (must sum to 1.0) ---
# Digital PDFs have lower ELA/Seal signal-to-noise ratio.
# Metadata is more reliable for native PDFs so it's weighted higher.
WEIGHT_ELA_DIGITAL=0.20
WEIGHT_METADATA_DIGITAL=0.45
WEIGHT_SEAL_DIGITAL=0.15
WEIGHT_NLP_DIGITAL=0.20

# --- CORS ---
# Restrict to your frontend URL in production
FRONTEND_URL=https://your-frontend-domain.com

# --- API Security ---
# REQUIRED in production. Must be a strong random secret (min 32 chars).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_SECRET=change-this-to-a-strong-secret-in-production

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
